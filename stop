#!/bin/sh
PID_FILE="document-service.pid"
if [ ! -f "$PID_FILE" ]; then
  echo "No PID file found. Is document-service running?"
  exit 1
fi
PID=$(cat "$PID_FILE")
if kill -0 "$PID" 2>/dev/null; then
  kill "$PID"
  echo "Stopped document-service (PID $PID)"
else
  echo "Process $PID not running. Cleaning up stale PID file."
  rm "$PID_FILE"
fi
